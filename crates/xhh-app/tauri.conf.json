{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "黑盒工坊",
  "version": "0.1.0",
  "identifier": "com.xhh.workshop",
  "build": {
    "frontendDist": "frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "frontend"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "frontend"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "黑盒工坊",
        "width": 1300,
        "height": 860,
        "minWidth": 1000,
        "minHeight": 700,
        "decorations": false,
        "center": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
